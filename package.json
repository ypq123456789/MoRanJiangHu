{
  "name": "墨色江湖---无尽武林",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "cnb:sync": "node scripts/cnb-image-backend-sync.mjs",
    "cnb:start": "node scripts/cnb-image-backend-sync.mjs --start",
    "cnb:workspace": "node scripts/cnb-workspace-start.mjs",
    "release:sync": "node scripts/sync-release.mjs",
    "release:bump": "node scripts/bump-release.mjs",
    "release:r2": "node scripts/publish-release-r2.mjs",
    "dev": "npm run release:sync && vite",
    "build": "npm run release:sync && vite build",
    "build:apk": "npm run release:sync && vite build --base=/",
    "preview": "vite preview",
    "apk:sync": "npm run build:apk && npx cap sync android",
    "apk:debug": "npm run apk:sync && cd android && gradlew.bat assembleDebug",
    "apk:release": "npm run apk:sync && cd android && gradlew.bat assembleRelease",
    "stress:test": "node scripts/promptStressTest.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "fflate": "^0.8.2",
    "js-tiktoken": "^1.0.21",
    "node": "^25.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
